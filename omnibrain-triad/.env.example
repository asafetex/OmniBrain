# OmniBrain TRIAD - Environment Variables
# Copy to .env and fill in your values

# Default timeout for CLI auditors (seconds)
# TRIAD_TIMEOUT_SECONDS=120

# Default encoding for file operations
# TRIAD_ENCODING=utf-8

# Path to ByteRover CLI (if not in PATH)
# Example (Windows): C:\Users\PC\AppData\Roaming\npm\node_modules\byterover-cli\bin\run.js
# Example (Unix/macOS): /usr/local/bin/brv
# TRIAD_BYTEROVER_CMD=

# Path to Codex CLI (if not in PATH)
# TRIAD_CODEX_CMD=codex

# Path to Gemini CLI (if not in PATH)
# TRIAD_GEMINI_CMD=gemini

# Path to DeepSeek CLI (if not in PATH)
# TRIAD_DEEPSEEK_CMD=deepseek

# Path to CodeRabbit CLI (if not in PATH)
# TRIAD_CODERABBIT_CMD=coderabbit
